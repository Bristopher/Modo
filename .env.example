# Copy to .env and adjust. Used by compose.yaml.

# ---- Core services (default `docker compose up`) ----

# Umbrella server image. Defaults to the published stable image.
# FLUXER_SERVER_IMAGE=ghcr.io/fluxerapp/fluxer-server:stable

# Host port for the umbrella HTTP server (API/admin/app/media). Container: 8080.
FLUXER_HTTP_PORT=8080

# Host port for the realtime WebSocket gateway. Must match services.gateway.port
# in config/config.json (8082 in the production template). Container: 8082.
FLUXER_GATEWAY_PORT=8082

# Optional NATS token auth. Off by default (NATS is internal-only, not exposed
# to the host). To enable: add '--auth=${NATS_AUTH_TOKEN}' to the nats command
# in compose.yaml AND set services.nats.auth_token to the same value in
# config/config.json.
# NATS_AUTH_TOKEN=

# ---- search profile (docker compose --profile search up) ----

# Required when the search profile is enabled. Must match
# integrations.search.api_key in config/config.json.
MEILI_MASTER_KEY=
MEILI_PORT=7700
ELASTICSEARCH_PORT=9200

# ---- voice profile (docker compose --profile voice up) ----
LIVEKIT_PORT=7880
