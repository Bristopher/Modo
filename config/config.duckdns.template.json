{
	"$schema": "../packages/config/src/ConfigSchema.json",
	"env": "production",
	"_comment": "Production self-host template. base_domain MUST match the FLUXER_BUILD_CONFIG build arg (.env BASE_DOMAIN) — rspack bakes these endpoint URLs into the SPA at build time. TLS is terminated by your Unraid reverse proxy (NPM/SWAG); Caddy inside the stack speaks plain http on 8080. public_scheme/public_port describe the PUBLIC URL your browser hits (https/443), not Caddy's internal port.",
	"domain": {
		"base_domain": "bigweld.duckdns.org",
		"public_scheme": "https",
		"public_port": 443,
		"endpoint_overrides": {
			"static_cdn": "https://fluxerstatic.com/static"
		}
	},
	"database": {
		"backend": "sqlite",
		"sqlite_path": "/usr/src/app/data/fluxer.db"
	},
	"internal": {
		"kv": "redis://valkey:6379/0",
		"kv_mode": "standalone"
	},
	"s3": {
		"access_key_id": "GENERATE",
		"secret_access_key": "GENERATE",
		"endpoint": "https://bigweld.duckdns.org/s3"
	},
	"services": {
		"server": {
			"port": 8080,
			"host": "0.0.0.0",
			"static_dir": "/usr/src/app/assets"
		},
		"s3": {
			"data_dir": "/usr/src/app/data/s3"
		},
		"media_proxy": {
			"secret_key": "GENERATE"
		},
		"admin": {
			"secret_key_base": "GENERATE",
			"oauth_client_secret": "GENERATE"
		},
		"marketing": {
			"enabled": false
		},
		"gateway": {
			"port": 8082,
			"admin_reload_secret": "GENERATE",
			"media_proxy_endpoint": "http://fluxer_server:8080/media"
		},
		"nats": {
			"core_url": "nats://nats:4222",
			"jetstream_url": "nats://nats:4222",
			"auth_token": ""
		}
	},
	"auth": {
		"sudo_mode_secret": "GENERATE",
		"connection_initiation_secret": "GENERATE",
		"vapid": {
			"public_key": "GENERATE",
			"private_key": "GENERATE"
		}
	},
	"integrations": {
		"email": {
			"enabled": true,
			"provider": "smtp",
			"from_email": "noreply@bigweld.duckdns.org",
			"smtp": {
				"host": "mailpit",
				"port": 1025,
				"username": "",
				"password": "",
				"secure": false
			}
		}
	}
}
